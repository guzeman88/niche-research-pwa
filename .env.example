# ─── Niche Research PWA — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.

# ─── LLM ────────────────────────────────────────────────────────────────────
# Ollama runs locally — no key needed. Just have 'ollama serve' running.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Gemini — free tier (1500 req/day). Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Claude — optional, highest quality. Get key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Reddit (optional — for community signal collection) ─────────────────────
# Create an app at https://www.reddit.com/prefs/apps → "script" type
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=niche-research-pwa/1.0 by u/your_username

# ─── eRank (optional — real Etsy search volumes) ────────────────────────────
ERANK_API_KEY=your_erank_api_key

# ─── Marmalead (optional — real Etsy SEO data) ──────────────────────────────
MARMALEAD_API_KEY=your_marmalead_api_key

# ─── Pinterest Trends (optional) ────────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token
