# ─── Niche Research PWA — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your values.

# ─── LLM ────────────────────────────────────────────────────────────────────
# Ollama runs locally — no key needed. Just have 'ollama serve' running.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Gemini — free tier (1500 req/day). Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Design generation safety
# External image providers are billing-locked by default even when a key exists.
# For free-tier testing, only add providers after confirming the account has no billing attached.
# Example: DESIGN_FREE_TIER_PROVIDERS=gemini
DESIGN_FREE_TIER_PROVIDERS=
# Set this to 1 only when you intentionally allow paid image generation.
DESIGN_ALLOW_PAID_PROVIDERS=0

# Optional image provider keys. Keep these server-side only; never expose them as VITE_ values.
IDEOGRAM_API_KEY=
RECRAFT_API_TOKEN=
KREA_API_KEY=
OPENAI_API_KEY=
STABILITY_API_KEY=
FAL_KEY=
REPLICATE_API_TOKEN=
BFL_API_KEY=
LUMA_API_KEY=
MAGNIFIC_API_KEY=
LEONARDO_API_KEY=

# Claude — optional, highest quality. Get key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Reddit (optional — for community signal collection) ─────────────────────
# Create an app at https://www.reddit.com/prefs/apps → "script" type
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=niche-research-pwa/1.0 by u/your_username

# ─── eRank (optional — real Etsy search volumes) ────────────────────────────
ERANK_API_KEY=your_erank_api_key

# Official Etsy Open API (recommended for real listing evidence)
# Create/manage an app at https://www.etsy.com/developers/your-apps
# Either provide the full header value:
ETSY_X_API_KEY=your_keystring:your_shared_secret
# Or provide separate parts:
ETSY_API_KEYSTRING=your_keystring
ETSY_SHARED_SECRET=your_shared_secret
# Optional: only needed for Etsy endpoints/scopes that require OAuth.
ETSY_OAUTH_TOKEN=
# HTML scraping is blocked-prone and disabled by default. Opt in only for local experiments.
ETSY_HTML_SCRAPER_ENABLED=0

# ─── Marmalead (optional — real Etsy SEO data) ──────────────────────────────
MARMALEAD_API_KEY=your_marmalead_api_key

# ─── Pinterest Trends (optional) ────────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token
